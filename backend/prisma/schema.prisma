generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int           @id @default(autoincrement())
  email       String        @unique
  name        String
  balance     Int           @default(0)
  password    String
  createdAt   DateTime      @default(now())
  transaction Transaction[]
  budgets     Budget?
}

model Transaction {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  type      Type
  amount    Int
  category  Category
  note      String?
  createdAt DateTime @default(now())
}

model Budget {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int      @unique
  limit     Int
  period    Period
  createdAt DateTime @default(now())
}

enum Period {
  weekly
  monthly
}

enum Type {
  expense
  income
}

enum Category {
  food
  transport
  shopping
  utilities
  work
  health
  allowance
  salary
  gift
  refund
  others
}
